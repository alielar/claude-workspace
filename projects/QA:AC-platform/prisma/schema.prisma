// Prisma schema for QA/AC Platform
// Using SQLite — zero setup, file stored at prisma/dev.db

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─────────────────────────────────────────
// CYCLE BATCHES
// A cycle PDF upload containing multiple individual pitches.
// Lifecycle: PROCESSING → COMPLETE | FAILED
// ─────────────────────────────────────────
model CycleBatch {
  id           String   @id @default(cuid())
  name         String   // e.g. "March Cycle"
  status       String   @default("PROCESSING")
  pdfPath      String
  totalPitches Int      @default(0)
  doneCount    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  pitches Pitch[]

  @@map("cycle_batches")
}

// ─────────────────────────────────────────
// PITCHES
// Lifecycle: UPLOADED → ANALYZING → CLARIFYING → COMPLETE → AC_GENERATED
// batchId is set when the pitch came from a cycle PDF upload.
// ─────────────────────────────────────────
model Pitch {
  id        String   @id @default(cuid())
  title     String
  pdfPath   String   // Local path relative to /public/uploads/
  rawText   String
  status    String   @default("UPLOADED") // SQLite stores enums as String
  batchId   String?  // null = single pitch upload
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batch      CycleBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  messages   Message[]
  acDocument AcDocument?

  @@map("pitches")
}

// ─────────────────────────────────────────
// MESSAGES
// Clarification chat per pitch.
// role: "assistant" = Claude, "user" = PM
// ─────────────────────────────────────────
model Message {
  id        String   @id @default(cuid())
  pitchId   String
  role      String   // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())

  pitch Pitch @relation(fields: [pitchId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// ─────────────────────────────────────────
// AC DOCUMENTS
// Generated ACs stored as markdown.
// ─────────────────────────────────────────
model AcDocument {
  id              String    @id @default(cuid())
  pitchId         String    @unique
  contentMarkdown String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  linearPushedAt  DateTime?
  linearProjectId String?

  pitch Pitch @relation(fields: [pitchId], references: [id], onDelete: Cascade)

  @@map("ac_documents")
}

// ─────────────────────────────────────────
// LINEAR CONFIG
// Single row — workspace-level Linear settings.
// ─────────────────────────────────────────
model LinearConfig {
  id             String  @id @default(cuid())
  apiKey         String
  defaultTeamId  String?
  defaultCycleId String?

  @@map("linear_config")
}
